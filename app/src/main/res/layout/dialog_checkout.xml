<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:padding="16dp">

    <androidx.cardview.widget.CardView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        app:cardCornerRadius="28dp"
        app:cardElevation="8dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="24dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:fontFamily="@font/semibold"
                android:text="Konfirmasi Pembayaran"
                android:textColor="@color/textColorPrimary"
                android:textSize="20sp" />

            <View
                android:layout_width="40dp"
                android:layout_height="4dp"
                android:layout_marginTop="8dp"
                android:background="@drawable/bg_cat_selected" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="24dp"
                android:fontFamily="@font/semibold"
                android:text="Rincian Pesanan"
                android:textColor="@color/textColorSecondary"
                android:textSize="14sp" />

            <androidx.core.widget.NestedScrollView
                android:layout_width="match_parent"
                android:layout_height="180dp"
                android:layout_marginTop="12dp"
                android:scrollbars="vertical">

                <LinearLayout
                    android:id="@+id/llCheckoutItems"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical" />
            </androidx.core.widget.NestedScrollView>

            <View
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:layout_marginTop="16dp"
                android:background="@color/dividerColor" />

            <RelativeLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:fontFamily="@font/semibold"
                    android:text="Total Tagihan"
                    android:textColor="@color/textColorPrimary"
                    android:textSize="16sp" />

                <TextView
                    android:id="@+id/tvCheckoutTotal"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_alignParentEnd="true"
                    android:fontFamily="@font/semibold"
                    android:text="Rp 0"
                    android:textColor="@color/textColorPrimary"
                    android:textSize="20sp" />
            </RelativeLayout>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="24dp"
                android:fontFamily="@font/semibold"
                android:text="Pilih Metode Pembayaran"
                android:textColor="@color/textColorSecondary"
                android:textSize="14sp" />

            <HorizontalScrollView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:clipToPadding="false"
                android:scrollbars="none">

                <RadioGroup
                    android:id="@+id/rgPayment"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:paddingBottom="8dp">

                    <RadioButton
                        android:id="@+id/rbCash"
                        android:layout_width="100dp"
                        android:layout_height="100dp"
                        android:layout_marginEnd="12dp"
                        android:background="@drawable/bg_cat_unselected"
                        android:button="@null"
                        android:checked="true"
                        android:drawableTop="@drawable/awal"
                        android:drawablePadding="8dp"
                        android:gravity="center"
                        android:padding="12dp"
                        android:text="Tunai"
                        android:textColor="@color/textColorPrimary"
                        android:textSize="11sp" />

                    <RadioButton
                        android:id="@+id/rbQris"
                        android:layout_width="100dp"
                        android:layout_height="100dp"
                        android:layout_marginEnd="12dp"
                        android:background="@drawable/bg_cat_unselected"
                        android:button="@null"
                        android:drawableTop="@drawable/logo_qris"
                        android:drawablePadding="8dp"
                        android:gravity="center"
                        android:padding="12dp"
                        android:text="QRIS"
                        android:textColor="@color/textColorPrimary"
                        android:textSize="11sp" />

                    <RadioButton
                        android:id="@+id/rbOvo"
                        android:layout_width="100dp"
                        android:layout_height="100dp"
                        android:layout_marginEnd="12dp"
                        android:background="@drawable/bg_cat_unselected"
                        android:button="@null"
                        android:drawableTop="@drawable/logo_ovo_purple"
                        android:drawablePadding="8dp"
                        android:gravity="center"
                        android:padding="12dp"
                        android:text="OVO"
                        android:textColor="@color/textColorPrimary"
                        android:textSize="11sp" />

                    <RadioButton
                        android:id="@+id/rbShopee"
                        android:layout_width="100dp"
                        android:layout_height="100dp"
                        android:layout_marginEnd="12dp"
                        android:background="@drawable/bg_cat_unselected"
                        android:button="@null"
                        android:drawableTop="@drawable/shopee"
                        android:drawablePadding="8dp"
                        android:gravity="center"
                        android:padding="12dp"
                        android:text="Shopee"
                        android:textColor="@color/textColorPrimary"
                        android:textSize="11sp" />

                    <RadioButton
                        android:id="@+id/rbBca"
                        android:layout_width="100dp"
                        android:layout_height="100dp"
                        android:layout_marginEnd="12dp"
                        android:background="@drawable/bg_cat_unselected"
                        android:button="@null"
                        android:drawableTop="@drawable/bank_central_asia"
                        android:drawablePadding="8dp"
                        android:gravity="center"
                        android:padding="12dp"
                        android:text="BCA"
                        android:textColor="@color/textColorPrimary"
                        android:textSize="11sp" />

                </RadioGroup>
            </HorizontalScrollView>

            <androidx.appcompat.widget.AppCompatButton
                android:id="@+id/btnProsesBayar"
                android:layout_width="match_parent"
                android:layout_height="58dp"
                android:layout_marginTop="24dp"
                android:background="@drawable/bg_cat_selected"
                android:fontFamily="@font/semibold"
                android:text="Konfirmasi &amp; Bayar"
                android:textAllCaps="false"
                android:textColor="@android:color/white"
                android:textSize="16sp"
                android:stateListAnimator="@null"
                android:elevation="4dp" />

        </LinearLayout>
    </androidx.cardview.widget.CardView>
</FrameLayout>
